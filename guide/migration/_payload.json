de.js 运行时，请确保它设置为版本 20、22 或更高。",[249,457,458],{"id":458},"类型导入",[242,460,461,462,465],{},"Nitro 类型现在仅从 ",[253,463,464],{},"nitro/types"," 导出。",[242,467,468,470,471,473,474,291],{},[278,469,280],{}," 从 ",[253,472,464],{}," 导入类型，而不是从 ",[253,475,259],{},[298,477,479],{"className":300,"code":478,"language":302,"meta":303,"style":303},"-- import { NitroRuntimeConfig } from \"nitropack\"\n++ import { NitroRuntimeConfig } from \"nitro/types\"\n",[253,480,481,486],{"__ignoreMap":303},[307,482,483],{"class":309,"line":310},[307,484,485],{},"-- import { NitroRuntimeConfig } from \"nitropack\"\n",[307,487,488],{"class":309,"line":316},[307,489,490],{},"++ import { NitroRuntimeConfig } from \"nitro/types\"\n",[249,492,493],{"id":493},"应用配置支持已移除",[242,495,496,497,500,501,504],{},"Nitro v2 支持一个捆绑的应用配置，可以在 ",[253,498,499],{},"app.config.ts"," 中定义配置，并通过 ",[253,502,503],{},"useAppConfig()"," 在运行时访问它们。",[242,506,507],{},"此功能已被移除。",[242,509,510],{},[278,511,280],{},[242,513,514,515,518],{},"在您的服务器目录中使用常规的 ",[253,516,517],{},".ts"," 文件并直接导入。",[249,520,521],{"id":521},"预设更新",[242,523,524],{},"Nitro 预设已更新以确保与最新版本兼容。",[242,526,527],{},"一些（遗留）预设已被移除或重命名。",[529,530,531,544],"table",{},[532,533,534],"thead",{},[535,536,537,541],"tr",{},[538,539,540],"th",{},"旧预设",[538,542,543],{},"新预设",[545,546,547,565,584,597,613,626,641,653,665,677,687,697,707],"tbody",{},[535,548,549,555],{},[550,551,552],"td",{},[253,553,554],{},"node",[550,556,557,560,561,564],{},[253,558,559],{},"node-middleware","（导出更改为 ",[253,562,563],{},"middleware","）",[535,566,567,579],{},[550,568,569,572,573,572,576],{},[253,570,571],{},"cloudflare",", ",[253,574,575],{},"cloudflare_worker",[253,577,578],{},"cloudflare_module_legacy",[550,580,581],{},[253,582,583],{},"cloudflare_module",[535,585,586,591],{},[550,587,588],{},[253,589,590],{},"deno-server-legacy",[550,592,593,596],{},[253,594,595],{},"deno_server","，使用 Deno v2",[535,598,599,604],{},[550,600,601],{},[253,602,603],{},"netlify-builder",[550,605,606,609,610],{},[253,60