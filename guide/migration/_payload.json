5,"icon":70},"/config","3.config/0.index",[236],{"title":67,"path":233,"stem":234,"icon":70},{"id":238,"title":12,"body":239,"description":307,"extension":806,"meta":807,"navigation":808,"path":13,"seo":809,"stem":14,"__hash__":810},"content/1.guide/00.migration.md",{"type":240,"value":241,"toc":796,"icon":15},"minimark",[242,249,252,264,279,296,301,348,358,373,377,387,390,402,417,421,430,439,443,460,463,470,480,495,498,509,512,516,523,526,529,532,722,725,728,763,769,773,792],[243,244,245],"note",{},[246,247,248],"p",{},"\n这是一个关于从 Nitro 2 迁移到 3 的活文档。在使用测试版时请定期检查。",[246,250,251],{},"Nitro v3 引入了故意的不向后兼容的更改。本指南帮助您从 Nitro v2 迁移。",[253,254,256,260,261],"h2",{"id":255},"nitropack-重命名为-nitro",[257,258,259],"code",{},"nitropack"," 重命名为 ",[257,262,263],{},"nitro",[246,265,266,267,273,274,278],{},"NPM 包 ",[268,269,259],"a",{"href":270,"rel":271},"https://www.npmjs.com/package/nitropack",[272],"nofollow","（v2）已更名为 ",[268,275,263],{"href":276,"rel":277},"https://www.npmjs.com/package/nitro",[272],"（v3）。",[246,280,281,285,286,289,290,292,293,295],{},[282,283,284],"strong",{},"迁移："," 在 ",[257,287,288],{},"package.json"," 中更新 ",[257,291,259],{}," 依赖为 ",[257,294,263],{},"：",[243,297,298],{},[246,299,300],{},"\n目前只提供夜间版本。",[302,303,308],"pre",{"className":304,"code":305,"language":306,"meta":307,"style":307},"language-diff shiki shiki-themes github-light github-dark github-dark","{\n  \"dependencies\": {\n--    \"nitropack\": \"latest\"\n++    \"nitro\": \"npm:nitro-nightly@latest\"\n  }\n}\n","diff","",[257,309,310,318,324,330,336,342],{"__ignoreMap":307},[311,312,315],"span",{"class":313,"line":314},"line",1,[311,316,317],{},"{\n",[311,319,321],{"class":313,"line":320},2,[311,322,323],{},"  \"dependencies\": {\n",[311,325,327],{"class":313,"line":326},3,[311,328,329],{},"--    \"nitropack\": \"latest\"\n",[311,331,333],{"class":313,"line":332},4,[311,334,335],{},"++    \"nitro\": \"npm:nitro-nightly@latest\"\n",[311,337,339],{"class":313,"line":338},5,[311,340,341],{},"  }\n",[311,343,345],{"class":313,"line":344},6,[311,346,347],{},"}\n",[246,349,350,352,353,355,356,295],{},[282,351,284],{}," 在您的代码库中搜索并将所有 ",[257,354,259],{}," 实例重命名为 ",[257,357,263],{},[302,359,361],{"className":304,"code":360,"language":306,"meta":307,"style":307},"-- import { defineNitroConfig } from \"nitropack/config\"\n++ import { defineNitroConfig } from \"nitro/config\"\n",[257,362,363,368],{"__ignoreMap":307},[311,364,365],{"class":313,"line":314},[311,366,367],{},"-- import { defineNitroConfig } from \"nitropack/config\"\n",[311,369,370],{"class":313,"line":320},[311,371,372],{},"++ import { defineNitroConfig } from \"nitro/config\"\n",[253,374,376],{"id":375},"nitroruntime","nitro/runtime/*",[246,378,379,380,383,384,386],{},"之前，您可以从 ",[257,381,382],{},"nitro/runtime"," 和 ",[257,385,376],{}," 导入。",[246,388,389],{},"为了防止暴露 Nitro 内部，已移除对嵌套路径的支持。",[246,391,392,394,395,398,399,401],{},[282,393,284],{}," 搜索 ",[257,396,397],{},"nitro/runtime/"," 导入，并用 ",[257,400,382],{}," 替换它们：",[302,403,405],{"className":304,"code":404,"language":306,"meta":307,"style":307},"-- import { useStorage } from \"nitropack/runtime/storage\"\n++ import { useStorage } from \"nitro/runtime\"\n",[257,406,407,412],{"__ignoreMap":307},[311,408,409],{"class":313,"line":314},[311,410,411],{},"-- import { useStorage } from \"nitropack/runtime/storage\"\n",[311,413,414],{"class":313,"line":320},[311,415,416],{},"++ import { useStorage } from \"nitro/runtime\"\n",[253,418,420],{"id":419},"最低支持的-nodejs-版本20","最低支持的 Node.js 版本：20",[246,422,423,424,429],{},"Nitro 现在要求最低 Node.js 版本为 20，因为 Node.js 18 将在 ",[268,425,428],{"href":426,"rel":427},"https://nodejs.org/en/about/previous-releases",[272],"2025 年 4 月"," 达到生命周期结束。",[246,431,432,433,438],{},"请升级到 ",[268,434,437],{"href":435,"rel":436},"https://nodejs.org/en/download",[272],"最新的 LTS"," 版本（>= 20）。",[246,440,441],{},[282,442,284],{},[444,445,446,454,457],"ul",{},[447,448,449,450,453],"li",{},"使用 ",[257,451,452],{},"node --version"," 检查您的本地 Node.js 版本，如有必要请更新。",[447,455,456],{},"如果您使用 CI/CD 系统进行部署，请确保您的管道正在运行 Node.js 20 或更高版本。",[447,458,459],{},"如果您的托管提供商管理 Node.js 运行时，请确保它设置为版本 20、22 或更高。",[253,461,462],{"id":462},"类型导入",[246,464,465,466,469],{},"Nitro 类型现在仅从 ",[257,467,468],{},"nitro/types"," 导出。",[246,471,472,474,475,477,478,295],{},[282,473,284],{}," 从 ",[257,476,468],{}," 导入类型，而不是从 ",[257,479,263],{},[302,481,483],{"className":304,"code":482,"language":306,"meta":307,"style":307},"-- import { NitroRuntimeConfig } from \"nitropack\"\n++ import { NitroRuntimeConfig } from \"nitro/types\"\n",[257,484,485,490],{"__ignoreMap":307},[311,486,487],{"class":313,"line":314},[311,488,489],{},"-- import { NitroRuntimeConfig } from \"nitropack\"\n",[311,491,492],{"class":313,"line":320},[311,493,494],{},"++ import { NitroRuntimeConfig } from \"nitro/types\"\n",[253,496,497],{"id":497},"应用配置支持已移除",[246,499,500,501,504,505,508],{},"Nitro v2 支持一个捆绑的应用配置，可以在 ",[257,502,503],{},"app.config.ts"," 中定义配置，并通过 ",[257,506,507],{},"useAppConfig()"," 在运行时访问它们。",[246,510,511],{},"此功能已被移除。",[246,513,514],{},[282,515,284],{},[246,517,518,519,522],{},"在您的服务器目录中使用常规的 ",[257,520,521],{},".ts"," 文件并直接导入。",[253,524,525],{"id":525},"预设更新",[246,527,528],{},"Nitro 预设已更新以确保与最新版本兼容。",[246,530,531],{},"一些（遗留）预设已被移除或重命名。",[533,534,535,548],"table",{},[536,537,538],"thead",{},[539,540,541,545],"tr",{},[542,543,544],"th",{},"旧预设",[542,546,547],{},"新预设",[549,550,551,569,588,601,617,630,645,657,669,681,693,703,713],"tbody",{},[539,552,553,559],{},[554,555,556],"td",{},[257,557,558],{},"node",[554,560,561,564,565,568],{},[257,562,563],{},"node-middleware","（导出更改为 ",[257,566,567],{},"middleware","）",[539,570,571,583],{},[554,572,573,576,577,576,580],{},[257,574,575],{},"cloudflare",", ",[257,578,579],{},"cloudflare_worker",[257,581,582],{},"cloudflare_module_legacy",[554,584,585],{},[257,586,587],{},"cloudflare_module",[539,589,590,595],{},[554,591,592],{},[257,593,594],{},"deno-server-legacy",[554,596,597,600],{},[257,598,599],{},"deno_server","，使用 Deno v2",[