,"title":379,"body":391,"description":5,"extension":401,"meta":402,"navigation":403,"path":375,"seo":404,"stem":380,"__hash__":405},"content/9.blog/index.md",{"type":392,"value":393,"toc":398,"icon":381},"minimark",[394],[395,396,397],"p",{},"Nitro 博客文章。",{"title":5,"searchDepth":399,"depth":399,"links":400},2,[],"md",{"icon":381},{"icon":381},{"title":379,"description":5},"5ST_nOo1uO-GkoYxXpm67eT_2AN8z_eue8pGAcfWLf4",[407],{"id":408,"title":383,"body":409,"description":1615,"extension":401,"meta":1616,"navigation":1623,"path":384,"seo":1624,"stem":385,"__hash__":1625},"content/9.blog/1.v3-beta.md",{"type":392,"value":410,"toc":1593,"icon":381},[411,415,426,441,480,488,492,517,520,535,541,545,553,641,648,677,693,697,700,723,737,743,756,763,824,831,835,842,940,944,981,984,1069,1072,1149,1152,1167,1171,1178,1194,1197,1206,1266,1269,1271,1274,1341,1343,1345,1352,1409,1411,1415,1421,1435,1438,1441,1444,1447,1449,1453,1461,1469,1478,1482,1485,1489,1496,1500,1503,1560,1565,1568,1571,1589],[412,413,414],"h2",{"id":414},"发展历程",[395,416,417,418,425],{},"Nitro 最初是作为 ",[419,420,424],"a",{"href":421,"rel":422},"https://nuxt.com",[423],"nofollow","Nuxt 3"," 的服务器引擎而诞生的，旨在解决一个特定问题：与部署环境无关的服务器。随着时间推移，Nitro 逐渐超越了 Nuxt 的范畴，成为许多元框架的基础，以及构建独立服务器的工具集。",[395,427,428,429,434,435,440],{},"在 Nitro v3 中，我们借此机会重新思考了基础架构：更精简的 API、Web 标准、一流的 ",[419,430,433],{"href":431,"rel":432},"https://rolldown.rs/",[423],"Rolldown"," 和 ",[419,436,439],{"href":437,"rel":438},"https://vite.dev/",[423],"Vite v8"," 集成，以及为开发者和 AI 助手提供的更好体验（稍后会详细介绍！）",[395,442,443,444,449,450,455,456,461,462,467,468,473,474,479],{},"自从我们在首届 ",[419,445,448],{"href":446,"rel":447},"https://viteconf.amsterdam/",[423],"Vite Conf"," 上悄悄发布 v3 ",[419,451,454],{"href":452,"rel":453},"https://github.com/nitrojs/nitro/releases/tag/v3.0.1-alpha.0",[423],"alpha.0","（2025 年 10 月 11 日）以来，Nitro v3 已被众多用户采用（每周下载量约 ",[419,457,460],{"href":458,"rel":459},"https://npmtrends.com/nitro-vs-nitro-nightly",[423],"28 万","！），并通过出色的贡献和反馈不断完善。包括 ",[419,463,466],{"href":464,"rel":465},"https://tanstack.com/start/latest/docs/framework/react/guide/hosting#nitro",[423],"Tanstack Start","、",[419,469,472],{"href":470,"rel":471},"https://useworkflow.dev/docs/getting-started",[423],"Vercel Workflows","，以及 ",[419,475,478],{"href":476,"rel":477},"https://t3.chat/",[423],"T3Chat"," 等生产环境应用。",[395,481,482,483,487],{},"衷心感谢 VoidZero（Vite 和 Rolldown）、Nuxt（",[419,484,486],{"href":485},"#nuxt-v5","v5 即将发布！","）和 TanStack Start 团队，以及每一位帮助 Nitro v3 达到这一里程碑的贡献者。❤️",[412,489,491],{"id":490},"为什么要构建服务器","为什么要构建服务器？",[395,493,494,495,499,500,503,504,507,508,511,512,516],{},"我们不会将原始源文件直接发送到浏览器。我们使用构建工具是因为它们能解决实际问题：",[496,497,498],"strong",{},"HMR"," 提供即时反馈，",[496,501,502],{},"代码分割","确保只加载路由所需的代码，",[496,505,506],{},"Tree Shaking"," 消除死代码，",[496,509,510],{},"压缩","减小体积。Webpack 和后来的 ",[419,513,515],{"href":437,"rel":514},[423],"Vite"," 等工具将前端开发从痛苦变得高效。",[395,518,519],{},"但前端应用并非孤立存在，它们需要 API、数据库、认证、实时数据。它们需要服务器。",[395,521,522,523,526,527,530,531,534],{},"随着无服务器和边缘计算的兴起，服务器端现在面临着前端多年前解决的相同约束。",[496,524,525],{},"冷启动","意味着每一毫秒的启动时间都至关重要。",[496,528,529],{},"内存限制","严格——臃肿的依赖可能让你超限。",[496,532,533],{},"包体积","直接影响部署速度和启动时间。而且你的代码需要处处运行：Node.js、Deno、Bun、Cloudflare Workers、Vercel 等。然而大多数服务器框架仍然发布未经优化、未打包的代码，假设一个长期运行的进程，而忽视了这一切。",[395,536,537,538],{},"Nitro 将构建工具的理念带到后端。你期望从前端工具获得的一流开发体验：用于快速迭代的 HMR，以及由 Rolldown 驱动的优化构建，带有 Tree Shaking 的生产输出，性能尽可能接近裸机。",[496,539,540],{},"一套代码，任何运行时，任何平台。",[412,542,544],{"id":543},"一流的-vite-集成","⚡ 一流的 Vite 集成",[395,546,547,548,552],{},"Nitro 现在拥有原生的 ",[419,549,515],{"href":550,"rel":551},"https://vite.dev",[423]," 插件，用于构建全栈应用。",[554,555,560],"pre",{"className":556,"code":557,"filename":558,"language":559,"meta":5,"style":5},"language-ts shiki shiki-themes github-light github-dark github-dark","import { defineConfig } from \"vite\";\nimport { nitro } from \"nitro/vite\";\n\nexport default defineConfig({\n  plugins: [nitro()],\n});\n","vite.config.ts","ts",[561,562,563,586,600,607,623,635],"code",{"__ignoreMap":5},[564,565,568,572,576,579,583],"span",{"class":566,"line":567},"line",1,[564,569,571],{"class":570},"so5gQ","import",[564,573,575],{"class":574},"slsVL"," { defineConfig } ",[564,577,578],{"class":570},"from",[564,580,582],{"class":581},"sfrk1"," \"vite\"",[564,584,585],{"class":574},";\n",[564,587,588,590,593,595,598],{"class":566,"line":399},[564,589,571],{"class":570},[564,591,592],{"class":574}," { nitro } ",[564,594,578],{"class":570},[564,596,597],{"class":581}," \"nitro/vite\"",[564,599,585],{"class":574},[564,601,603],{"class":566,"line":602},3,[564,604,606],{"emptyLinePlaceholder":605},true,"\n",[564,608,610,613,616,620],{"class":566,"line":609},4,[564,611,612],{"class":570},"export",[564,614,615],{"class":570}," default",[564,617,619],{"class":618},"shcOC"," defineConfig",[564,621,622],{"class":574},"({\n",[564,624,626,629,632],{"class":566,"line":625},5,[564,627,628],{"class":574},"  plugins: [",[564,630,631],{"class":618},"nitro",[564,633,634],{"class":574},"()],\n",[564,636,638],{"class":566,"line":637},6,[564,639,640],{"class":574},"});\n",[395,642,643,644,647],{},"在你的 Vite 应用中添加 ",[561,645,646],{},"nitro()"," 即可获得：",[649,650,651,657,663],"ul",{},[652,653,654,655],"li",{},"通过文件系统路由实现的 ",[496,656,225],{},[652,658,659,660],{},"与你的前端构建集成的 ",[496,661,662],{},"服务端渲染",[652,664,665,668,669,672,673,676],{},[496,666,667],{},"生产环境服务器","——单次 ",[561,670,671],{},"vite build"," 即可生成优化的 ",[561,674,675],{},".output/"," 文件夹，包含前后端，随时可部署",[395,678,679,680,467,683,434,686,689,690,692],{},"这意味着你可以为任何 Vite 项目添加完整的后端——查看 ",[419,681,682],{"href":342},"React",[419,684,685],{"href":360},"Vue",[419,687,688],{"href":346},"Solid.js"," 的",[419,691,218],{"href":219},"。",[412,694,696],{"id":695},"默认高性能零膨胀","🚀 默认高性能，零膨胀",[395,698,699],{},"Nitro 在构建时编译你的路由。没有运行时路由器——每个路由按需加载。只有处理特定请求所需的代码才会被加载和执行。",[395,701,702,703,706,707,710,711,716,717,722],{},"使用 ",[561,704,705],{},"standard"," 预设构建的极简服务器包小于 ",[561,708,709],{},"10kB","，可以使用 ",[419,712,715],{"href":713,"rel":714},"https://srvx.h3.dev/",[423],"srvx"," 以接近原生的速度提供服务，并包含 ",[419,718,721],{"href":719,"rel":720},"https://h3.dev/",[423],"H3"," 的所有优秀特性。",[395,724,725,726,731,732,692],{},"我们还显著减少了依赖数量，从 ",[419,727,730],{"href":728,"rel":729},"https://npmgraph.js.org/?q=nitropack",[423],"321 个依赖"," 减少到 ",[419,733,736],{"href":734,"rel":735},"https://npmgraph.js.org/?q=nitro-nightly",[423],"不足 20 个",[412,738,740,741],{"id":739},"️-新身份nitro","🖌️ 新身份：",[561,742,631],{},[395,744,745,746,752,753,692],{},"Nitro v3 使用新的 NPM 包发布：",[419,747,750],{"href":748,"rel":749},"https://npmx.dev/package/nitro",[423],[561,751,631],{},"，替代了旧版的 ",[561,754,755],{},"nitropack",[395,757,758,759,762],{},"所有导入现在使用简洁的 ",[561,760,761],{},"nitro/*"," 子路径：",[554,764,766],{"className":556,"code":765,"language":559,"meta":5,"style":5},"import { defineNitroConfig } from \"nitro/config\";\nimport { defineHandler } from \"nitro\";\nimport { useStorage } from \"nitro/storage\";\nimport { useDatabase } from \"nitro/database\";\n",[561,767,768,782,796,810],{"__ignoreMap":5},[564,769,770,772,775,777,780],{"class":566,"line":567},[564,771,571],{"class":570},[564,773,774],{"class":574}," { defineNitroConfig } ",[564,776,578],{"class":570},[564,778,779],{"class":581}," \"nitro/config\"",[564,781,585],{"class":574},[564,783,784,786,789,791,794],{"class":566,"line":399},[564,785,571],{"class":570},[564,787,788],{"class":574}," { defineHandler } ",[564,790,578],{"class":570},[564,792,793],{"class":581}," \"nitro\"",[564,795,585],{"class":574},[564,797,798,800,803,805,808],{"class":566,"line":602},[564,799,571],{"class":570},[564,801,802],{"class":574}," { useStorage } ",[564,804,578],{"class":570},[564,806,807],{"class":581}," \"nitro/storage\"",[564,809,585],{"class":574},[564,811,812,814,817,819,822],{"class":566,"line":609},[564,813,571],{"class":570},[564,815,816],{"class":574}," { useDatabase } ",[564,818,578],{"class":570},[564,820,821],{"class":581}," \"nitro/database\"",[564,823,585],{"class":574},[395,825,826,827,830],{},"不再有深层的 ",[561,828,829],{},"nit