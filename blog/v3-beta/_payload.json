app",[399,1475,1476,1477,1480],{},"查看",[403,1478,1479],{"href":14},"快速入门指南","获取完整的分步教程。",[395,1482,1484],{"id":1483},"从-v2-迁移","🔄 从 v2 迁移",[399,1486,1487],{},"Nitro v3 引入了有意的破坏性变更，以建立更简洁的基础。以下是关键变更：",[634,1489,1490,1498,1505,1514,1522,1529,1535],{},[637,1491,1492,1494,1495,1497],{},[545,1493,740],{}," → ",[545,1496,616],{},"（包重命名）",[637,1499,1500,1494,1502,1504],{},[545,1501,814],{},[545,1503,746],{},"（简洁的子路径导入）",[637,1506,1507,1494,1510,1513],{},[545,1508,1509],{},"eventHandler",[545,1511,1512],{},"defineHandler","（H3 v2）",[637,1515,1516,1494,1519,1513],{},[545,1517,1518],{},"createError",[545,1520,1521],{},"HTTPError",[637,1523,1524,1525,1528],{},"Web 标准的 ",[545,1526,1527],{},"event.req"," 请求头和请求体 API",[637,1530,1531,1532],{},"Node.js 最低版本：",[480,1533,1534],{},"20",[637,1536,1537,1538,1494,1541,1544],{},"预设重命名和整合（例如，",[545,1539,1540],{},"cloudflare",[545,1542,1543],{},"cloudflare_module","）",[399,1546,1547,1548,677],{},"完整列表请参见",[403,1549,73],{"href":74},[1551,1552],"hr",{},[399,1554,1555],{},"感谢多年来为 Nitro 做出贡献的每一个人。我们迫不及待想看到你用新版 Nitro 构建的作品！❤️",[634,1557,1558,1566],{},[637,1559,1560,1565],{},[403,1561,1564],{"href":1562,"rel":1563},"https://github.com/nitrojs/nitro",[407],"GitHub"," — 问题与讨论",[637,1567,1568,1573],{},[403,1569,1572],{"href":1570,"rel":1571},"https://discord.nitro.build",[407],"Discord"," — 与社区交流",[1575,1576,1577],"style",{},"html pre.shiki code .so5gQ, html code.shiki .so5gQ{--shiki-light:#D73A49;--shiki-default:#F97583;--shiki-dark:#F97583}html pre.shiki code .slsVL, html code.shiki .slsVL{--shiki-light:#24292E;--shiki-default:#E1E4E8;--shiki-dark:#E1E4E8}html pre.shiki code .sfrk1, html code.shiki .sfrk1{--shiki-light:#032F62;--shiki-default:#9ECBFF;--shiki-dark:#9ECBFF}html pre.shiki code .shcOC, html code.shiki .shcOC{--shiki-light:#6F42C1;--shiki-default:#B392F0;--shiki-dark:#B392F0}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-