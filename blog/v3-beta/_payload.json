83,"body":391,"description":1600,"extension":1601,"meta":1602,"navigation":1609,"path":384,"seo":1610,"stem":385,"__hash__":1611},"content/9.blog/1.v3-beta.md",{"type":392,"value":393,"toc":1578,"icon":381},"minimark",[394,398,410,425,464,472,476,501,504,519,525,529,537,626,633,662,678,682,685,708,722,728,741,748,809,816,820,827,925,929,966,969,1054,1057,1134,1137,1152,1156,1163,1179,1182,1191,1251,1254,1256,1259,1326,1328,1330,1337,1394,1396,1400,1406,1420,1423,1426,1429,1432,1434,1438,1446,1454,1463,1467,1470,1474,1481,1485,1488,1545,1550,1553,1556,1574],[395,396,397],"h2",{"id":397},"发展历程",[399,400,401,402,409],"p",{},"Nitro 最初是作为 ",[403,404,408],"a",{"href":405,"rel":406},"https://nuxt.com",[407],"nofollow","Nuxt 3"," 的服务器引擎而诞生的，旨在解决一个特定问题：与部署环境无关的服务器。随着时间推移，Nitro 逐渐超越了 Nuxt 的范畴，成为许多元框架的基础，以及构建独立服务器的工具集。",[399,411,412,413,418,419,424],{},"在 Nitro v3 中，我们借此机会重新思考了基础架构：更精简的 API、Web 标准、一流的 ",[403,414,417],{"href":415,"rel":416},"https://rolldown.rs/",[407],"Rolldown"," 和 ",[403,420,423],{"href":421,"rel":422},"https://vite.dev/",[407],"Vite v8"," 集成，以及为开发者和 AI 助手提供的更好体验（稍后会详细介绍！）",[399,426,427,428,433,434,439,440,445,446,451,452,457,458,463],{},"自从我们在首届 ",[403,429,432],{"href":430,"rel":431},"https://viteconf.amsterdam/",[407],"Vite Conf"," 上悄悄发布 v3 ",[403,435,438],{"href":436,"rel":437},"https://github.com/nitrojs/nitro/releases/tag/v3.0.1-alpha.0",[407],"alpha.0","（2025 年 10 月 11 日）以来，Nitro v3 已被众多用户采用（每周下载量约 ",[403,441,444],{"href":442,"rel":443},"https://npmtrends.com/nitro-vs-nitro-nightly",[407],"28 万","！），并通过出色的贡献和反馈不断完善。包括 ",[403,447,450],{"href":448,"rel":449},"https://tanstack.com/start/latest/docs/framework/react/guide/hosting#nitro",[407],"Tanstack Start","、",[403,453,456],{"href":454,"rel":455},"https://useworkflow.dev/docs/getting-started",[407],"Vercel Workflows","，以及 ",[403,459,462],{"href":460,"rel":461},"https://t3.chat/",[407],"T3Chat"," 等生产环境应用。",[399,465,466,467,471],{},"衷心感谢 VoidZero（Vite 和 Rolldown）、Nuxt（",[403,468,470],{"href":469},"#nuxt-v5","v5 即将发布！","）和 TanStack Start 团队，以及每一位帮助 Nitro v3 达到这一里程碑的贡献者。❤️",[395,473,475],{"id":474},"为什么要构建服务器","为什么要构建服务器？",[399,477,478,479,483,484,487,488,491,492,495,496,500],{},"我们不会将原始源文件直接发送到浏览器。我们使用构建工具是因为它们能解决实际问题：",[480,481,482],"strong",{},"HMR"," 提供即时反馈，",[480,485,486],{},"代码分割","确保只加载路由所需的代码，",[480,489,490],{},"Tree Shaking"," 消除死代码，",[480,493,494],{},"压缩","减小体积。Webpack 和后来的 ",[403,497,499],{"href":421,"rel":498},[407],"Vite"," 等工具将前端开发从痛苦变得高效。",[399,502,503],{},"但前端应用并非孤立存在，它们需要 API、数据库、认证、实时数据。它们需要服务器。",[399,505,506,507,510,511,514,515,518],{},"随着无服务器和边缘计算的兴起，服务器端现在面临着前端多年前解决的相同约束。",[480,508,509],{},"冷启动","意味着每一毫秒的启动时间都至关重要。",[480,512,513],{},"内存限制","严格——臃肿的依赖可能让你超限。",[480,516,517],{},"包体积","直接影响部署速度和启动时间。而且你的代码需要处处运行：Node.js、Deno、Bun、Cloudflare Workers、Vercel 等。然而大多数服务器框架仍然发布未经优化、未打包的代码，假设一个长期运行的进程，而忽视了这一切。",[399,520,521,522],{},"Nitro 将构建工具的理念带到后端。你期望从前端工具获得的一流开发体验：用于快速迭代的 HMR，以及由 Rolldown 驱动的优化构建，带有 Tree Shaking 的生产输出，性能尽可能接近裸机。",[480,523,524],{},"一套代码，任何运行时，任何平台。",[395,526,528],{"id":527},"一流的-vite-集成","⚡ 一流的 Vite 集成",[399,530,531,532,536],{},"Nitro 现在拥有原生的 ",[403,533,499],{"href":534,"rel":535},"https://vite.dev",[407]," 插件，用于构建全栈应用。",[538,539,544],"pre",{"className":540,"code":541,"filename":542,"language":543,"meta":5,"style":5},"language-ts shiki shiki-themes github-light github-dark github-dark","import { defineConfig } from \"vite\";\nimport { nitro } from \"nitro/vite\";\n\nexport default defineConfig({\n  plugins: [nitro()],\n});\n","vite.config.ts","ts",[545,546,547,570,585,592,608,620],"code",{"__ignoreMap":5},[548,549,552,556,560,563,567],"span",{"class":550,"line":551},"line",1,[548,553,555],{"class":554},"so5gQ","import",[548,557,559],{"class":558},"slsVL"," { defineConfig } ",[548,561,562],{"class":554},"from",[548,564,566],{"class":565},"sfrk1"," \"vite\"",[548,568,569],{"class":558},";\n",[548,571,573,575,578,580,583],{"class":550,"line":572},2,[548,574,555],{"class":554},[548,576,577],{"class":558}," { nitro } ",[548,579,562],{"class":554},[548,581,582],{"class":565}," \"nitro/vite\"",[548,584,569],{"class":558},[548,586,588],{"class":550,"line":587},3,[548,589,591],{"emptyLinePlaceholder":590},true,"\n",[548,593,595,598,601,605],{"class":550,"line":594},4,[548,596,597],{"class":554},"export",[548,599,600],{"class":554}," default",[548,602,604],{"class":603},"shcOC"," defineConfig",[548,606,607],{"class":558},"({\n",[548,609,611,614,617],{"class":550,"line":610},5,[548,612,613],{"class":558},"  plugins: [",[548,615,616],{"class":603},"nitro",[548,618,619],{"class":558},"()],\n",[548,621,623],{"class":550,"line":622},6,[548,624,625],{"class":558},"});\n",[399,627,628,629,632],{},"在你的 Vite 应用中添加 ",[545,630,631],{},"nitro()"," 即可获得：",[634,635,636,642,648],"ul",{},[637,638,639,640],"li",{},"通过文件系统路由实现的 ",[480,641,225],{},[637,643,644,645],{},"与你的前端构建集成的 ",[480,646,647],{},"服务端渲染",[637,649,650,653,654,657,658,661],{},[480,651,652],{},"生产环境服务器","——单次 ",[545,655,656],{},"vite build"," 即可生成优化的 ",[545,659,660],{},".output/"," 文件夹，包含前后端，随时可部署",[399,663,664,665,451,668,418,671,674,675,677],{},"这意味着你可以为任何 Vite 项目添加完整的后端——查看 ",[403,666,667],{"href":342},"React",[403,669,670],{"href":360},"Vue",[403,672,673],{"href":346},"Solid.js"," 的",[403,676,218],{"href":219},"。",[395,679,681],{"id":680},"默认高性能零膨胀","🚀 默认高性能，零膨胀",[399,683,684],{},"Nitro 在构建时编译你的路由。没有运行时路由器——每个路由按需加载。只有处理特定请求所需的代码才会被加载和执行。",[399,686,687,688,691,692,695,696,701,702,707],{},"使用 ",[545,689,690],{},"standard"," 预设构建的极简服务器包小于 ",[545,693,694],{},"10kB","，可以使用 ",[403,697,700],{"href":698,"rel":699},"https://srvx.h3.dev/",[407],"srvx"," 以接近原生的速度提供服务，并包含 ",[403,703,706],{"href":704,"rel":705},"https://h3.dev/",[407],"H3"," 的所有优秀特性。",[399,709,710,711,716,717,677],{},"我们还显著减少了依赖数量，从 ",[403,712,715],{"href":713,"rel":714},"https://npmgraph.js.org/?q=nitropack",[407],"321 个依赖"," 减少到 ",[403,718,721],{"href":719,"rel":720},"https://npmgraph.js.org/?q=nitro-nightly",[407],"不足 20 个",[395,723,725,726],{"id":724},"️-新身份nitro","🖌️ 新身份：",[545,727,616],{},[399,729,