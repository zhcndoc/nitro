"id":234,"title":98,"body":235,"description":570,"extension":571,"meta":572,"navigation":573,"path":99,"seo":574,"stem":100,"__hash__":575},"content/2.deploy/10.runtimes/1.node.md",{"type":236,"value":237,"toc":563,"icon":101},"minimark",[238,250,253,256,278,285,310,317,321,324,417,421,428,431,434,440,448,452,459,466,475,480,559],[239,240,241,245,246],"p",{},[242,243,244],"strong",{},"预设:"," ",[247,248,249],"code",{},"node_server",[239,251,252],{},"Node.js 是生产构建的默认 Nitro 输出预设，并且 Nitro 原生支持 Node.js 运行时。",[239,254,255],{},"使用 nitro CLI 构建项目：",[257,258,263],"pre",{"className":259,"code":260,"language":261,"meta":262,"style":262},"language-bash shiki shiki-themes github-light github-dark github-dark","nitro build\n","bash","",[247,264,265],{"__ignoreMap":262},[266,267,270,274],"span",{"class":268,"line":269},"line",1,[266,271,273],{"class":272},"shcOC","nitro",[266,275,277],{"class":276},"sfrk1"," build\n",[239,279,280,281,284],{},"当使用 Node 服务器预设运行 ",[247,282,283],{},"nitro build"," 时，结果将是一个启动准备就绪的 Node 服务器的入口点。要尝试输出：",[257,286,288],{"className":259,"code":287,"language":261,"meta":262,"style":262},"$ node .output/server/index.mjs\n正在监听 http://localhost:3000\n",[247,289,290,301],{"__ignoreMap":262},[266,291,292,295,298],{"class":268,"line":269},[266,293,294],{"class":272},"$",[266,296,297],{"class":276}," node",[266,299,300],{"class":276}," .output/server/index.mjs\n",[266,302,304,307],{"class":268,"line":303},2,[266,305,306],{"class":272},"正在监听",[266,308,309],{"class":276}," http://localhost:3000\n",[239,311,312,313,316],{},"您现在可以将完全独立的 ",[247,314,315],{},".output"," 目录部署到您选择的托管服务。",[318,319,320],"h3",{"id":320},"环境变量",[239,322,323],{},"您可以使用以下环境变量自定义服务器行为：",[325,326,327,342,350,356,366,383,392,402],"ul",{},[328,329,330,333,334,337,338,341],"li",{},[247,331,332],{},"NITRO_PORT"," 或 ",[247,335,336],{},"PORT","（默认为 ",[247,339,340],{},"3000","）",[328,343,344,333,347],{},[247,345,346],{},"NITRO_HOST",[247,348,349],{},"HOST",[328,351,352,355],{},[247,353,354],{},"NITRO_UNIX_SOCKET"," - 如果提供（一个指向所需套接字文件的路径），则服务将通过提供的 UNIX 套接字提供服务。",[328,357,358,361,362,365],{},[247,359,360],{},"NITRO_SSL_CERT"," 和 ",[247,363,364],{},"NITRO_SSL_KEY"," - 如果两者都存在，则服务器将在 HTTPS 模式下启动。在绝大多数情况下，这不应在生产中使用，Nitro 服务器应位于反向代理后，例如 nginx 或 Cloudflare，该代理终止 SSL。",[328,367,368,371,372,375,376,378,379,382],{},[247,369,370],{},"NITRO_SHUTDOWN_DISABLED"," - 当设置为 ",[247,373,374],{},"'true'"," 时，禁用优雅关闭功能。如果设置为 ",[247,377,374],{},"，则将跳过优雅关闭以加速开发过程。默认为 ",[247,380,381],{},"'false'","。",[328,384,385,388,389,382],{},[247,386,387],{},"NITRO_SHUTDOWN_SIGNALS"," - 允许您指定应处理哪些信号。每个信号应以空格分隔。默认为 ",[247,390,391],{},"'SIGINT SIGTERM'",[328,393,394,397,398,401],{},[247,395,396],{},"NITRO_SHUTDOWN_TIMEOUT"," - 设置强制关闭发生前的时间（以毫秒为单位）。默认为 ",[247,399,400],{},"'30000'"," 毫秒。",[328,403,404,407,408,411,412,414,415,382],{},[247,405,406],{},"NITRO_SHUTDOWN_FORCE"," - 当设置为 true 时，在关闭过程结束时触发 ",[247,409,410],{},"process.exit()","。如果设置为 ",[247,413,381],{},"，进程将简单地让事件循环清理。默认为 ",[247,416,374],{},[418,419,420],"h2",{"id":420},"集群模式",[239,422,423,245,425],{},[242,424,244],{},[247,426,427],{},"node_cluster",[239,429,430],{},"为了更高的性能并利用多核处理，您可以使用集群预设。",[318,432,320],{"id":433},"环境变量-1",[239,435,436,437,439],{},"除了来自 ",[247,438,249],{}," 预设的环境变量，您还可以自定义行为：",[325,441,442],{},[328,443,444,447],{},[247,445,446],{},"NITRO_CLUSTER_WORKERS",": 集群工作进程的数量（默认为可用 CPU 内核数量）",[418,449,451],{"id":450},"处理程序高级","处理程序（高级）",[239,453,454,245,456],{},[242,455,244],{},[247,457,458],{},"node",[239,460,461,462,465],{},"Nitro 还有一个更低级的预设，直接导出一个具有 ",[247,463,464],{},"(req, res) => {}"," 签名的函数，可用于中间件和自定义服务器。",[239,467,468,469,471,472,474],{},"当使用 Node 预设运行 ",[247,470,283],{}," 时，结果将是一个导出具有 ",[247,473,464],{}," 签名的函数的入口点。",[239,476,477],{},[242,478,479],{},"示例：",[257,481,485],{"className":482,"code":483,"language":484,"meta":262,"style":262},"language-js shiki shiki-themes github-light github-dark github-dark","import { createServer } from 'node:http'\nimport { listener } from './.output/server'\n\nconst server = createServer(listener