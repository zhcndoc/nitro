,"stem":388},"/","index",{"id":390,"title":96,"body":391,"description":721,"extension":722,"meta":723,"navigation":724,"path":97,"seo":725,"stem":98,"__hash__":726},"content/2.deploy/10.runtimes/1.node.md",{"type":392,"value":393,"toc":714,"icon":99},"minimark",[394,406,409,412,433,440,468,475,479,482,575,579,586,589,592,598,606,610,617,620,626,631,710],[395,396,397,401,402],"p",{},[398,399,400],"strong",{},"预设："," ",[403,404,405],"code",{},"node_server",[395,407,408],{},"Node.js 是生产构建的默认 Nitro 输出预设，且 Nitro 原生支持 Node.js 运行时。",[395,410,411],{},"使用 Nitro CLI 构建项目：",[413,414,418],"pre",{"className":415,"code":416,"language":417,"meta":5,"style":5},"language-bash shiki shiki-themes github-light github-dark github-dark","nitro build\n","bash",[403,419,420],{"__ignoreMap":5},[421,422,425,429],"span",{"class":423,"line":424},"line",1,[421,426,428],{"class":427},"shcOC","nitro",[421,430,432],{"class":431},"sfrk1"," build\n",[395,434,435,436,439],{},"当使用 Node 服务器预设运行 ",[403,437,438],{},"nitro build"," 时，结果将是一个启动即可运行的 Node 服务器的入口点。要试运行输出：",[413,441,443],{"className":415,"code":442,"language":417,"meta":5,"style":5},"$ node .output/server/index.mjs\nListening on http://localhost:3000\n",[403,444,445,456],{"__ignoreMap":5},[421,446,447,450,453],{"class":423,"line":424},[421,448,449],{"class":427},"$",[421,451,452],{"class":431}," node",[421,454,455],{"class":431}," .output/server/index.mjs\n",[421,457,459,462,465],{"class":423,"line":458},2,[421,460,461],{"class":427},"Listening",[421,463,464],{"class":431}," on",[421,466,467],{"class":431}," http://localhost:3000\n",[395,469,470,471,474],{},"你现在可以将完全独立的 ",[403,472,473],{},".output"," 目录部署到你选择的托管服务上。",[476,477,478],"h3",{"id":478},"环境变量",[395,480,481],{},"你可以使用以下环境变量自定义服务器行为：",[483,484,485,500,508,514,524,541,550,560],"ul",{},[486,487,488,491,492,495,496,499],"li",{},[403,489,490],{},"NITRO_PORT"," 或 ",[403,493,494],{},"PORT","（默认为 ",[403,497,498],{},"3000","）",[486,501,502,491,505],{},[403,503,504],{},"NITRO_HOST",[403,506,507],{},"HOST",[486,509,510,513],{},[403,511,512],{},"NITRO_UNIX_SOCKET"," - 如果提供（指向所需套接字文件的路径），服务将通过提供的 UNIX 套接字提供服务。",[486,515,516,519,520,523],{},[403,517,518],{},"NITRO_SSL_CERT"," 和 ",[403,521,522],{},"NITRO_SSL_KEY"," - 如果两者都存在，这将以 HTTPS 模式启动服务器。在绝大多数情况下，除了测试之外不应使用此功能，Nitro 服务器应该运行在像 nginx 或 Cloudflare 这样的反向代理后面，由它们来终止 SSL。",[486,525,526,529,530,533,534,536,537,540],{},[403,527,528],{},"NITRO_SHUTDOWN_DISABLED"," - 当设置为 ",[403,531,532],{},"'true'"," 时禁用优雅关闭功能。如果设置为 ",[403,535,532],{},"，将绕过优雅关闭以加快开发过程。默认为 ",[403,538,539],{},"'false'","。",[486,542,543,546,547,540],{},[403,544,545],{},"NITRO_SHUTDOWN_SIGNALS"," - 允许你指定应处理哪些信号。每个信号应以空格分隔。默认为 ",[403,548,549],{},"'SIGINT SIGTERM'",[486,551,552,555,556,559],{},[403,553,554],{},"NITRO_SHUTDOWN_TIMEOUT"," - 设置在强制关闭前的时间（以毫秒为单位）。默认为 ",[403,557,558],{},"'30000'"," 毫秒。",[486,561,562,565,566,569,570,572,573,540],{},[403,563,564],{},"NITRO_SHUTDOWN_FORCE"," - 当设置为 true 时，在关闭过程结束时触发 ",[403,567,568],{},"process.exit()","。如果设置为 ",[403,571,539],{},"，进程将只是让事件循环清空。默认为 ",[403,574,532],{},[576,577,578],"h2",{"id":578},"集群模式",[395,580,581,401,583],{},[398,582,400],{},[403,584,585],{},"node_cluster",[395,587,588],{},"为了获得更好的性能并利用多核处理能力，你可以使用集群预设。",[476,590,478],{"id":591},"环境变量-1",[395,593,594,595,597],{},"除了 ",[403,596,405],{}," 预设的环境变量外，你还可以自定义行为：",[483,599,600],{},[486,601,602,605],{},[403,603,604],{},"NITRO_CLUSTER_WORKERS","：集群工作进程数（默认为可用的 CPU 核心数）",[576,607,609],{"id":608},"处理器高级","处理器（高级）",[395,611,612,401,614],{},[398,613,400],{},[403,615,616],{},"node_middleware",[395,618,619],{},"Nitro 还有一个更低级的预设，直接导出一个可用于自定义服务器的中间件。",[395,621,622,623,625],{},"当使用 Node 中间件预设运行 ",[403,624,438],{}," 时，结果将是一个导出中间件处理程序的入口点。",[395,627,628],{},[398,629,630],{},"示例：",[413,632,636],{"className":633,"code":634,"language":635,"meta":5,"style":5},"language-js shiki shiki-themes github-light github-dark github-dark","import { createServer } from 'node:http'\nimport { listener } from './.output/server'\n\nconst server = createServer(listener)\nserver.listen