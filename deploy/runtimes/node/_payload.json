ildren":235,"icon":70},"/config","3.config/0.index",[236],{"title":67,"path":233,"stem":234,"icon":70},{"id":238,"title":98,"body":239,"description":574,"extension":575,"meta":576,"navigation":577,"path":99,"seo":578,"stem":100,"__hash__":579},"content/2.deploy/10.runtimes/1.node.md",{"type":240,"value":241,"toc":567,"icon":101},"minimark",[242,254,257,260,282,289,314,321,325,328,421,425,432,435,438,444,452,456,463,470,479,484,563],[243,244,245,249,250],"p",{},[246,247,248],"strong",{},"预设:"," ",[251,252,253],"code",{},"node_server",[243,255,256],{},"Node.js 是生产构建的默认 Nitro 输出预设，并且 Nitro 原生支持 Node.js 运行时。",[243,258,259],{},"使用 nitro CLI 构建项目：",[261,262,267],"pre",{"className":263,"code":264,"language":265,"meta":266,"style":266},"language-bash shiki shiki-themes github-light github-dark github-dark","nitro build\n","bash","",[251,268,269],{"__ignoreMap":266},[270,271,274,278],"span",{"class":272,"line":273},"line",1,[270,275,277],{"class":276},"shcOC","nitro",[270,279,281],{"class":280},"sfrk1"," build\n",[243,283,284,285,288],{},"当使用 Node 服务器预设运行 ",[251,286,287],{},"nitro build"," 时，结果将是一个启动准备就绪的 Node 服务器的入口点。要尝试输出：",[261,290,292],{"className":263,"code":291,"language":265,"meta":266,"style":266},"$ node .output/server/index.mjs\n正在监听 http://localhost:3000\n",[251,293,294,305],{"__ignoreMap":266},[270,295,296,299,302],{"class":272,"line":273},[270,297,298],{"class":276},"$",[270,300,301],{"class":280}," node",[270,303,304],{"class":280}," .output/server/index.mjs\n",[270,306,308,311],{"class":272,"line":307},2,[270,309,310],{"class":276},"正在监听",[270,312,313],{"class":280}," http://localhost:3000\n",[243,315,316,317,320],{},"您现在可以将完全独立的 ",[251,318,319],{},".output"," 目录部署到您选择的托管服务。",[322,323,324],"h3",{"id":324},"环境变量",[243,326,327],{},"您可以使用以下环境变量自定义服务器行为：",[329,330,331,346,354,360,370,387,396,406],"ul",{},[332,333,334,337,338,341,342,345],"li",{},[251,335,336],{},"NITRO_PORT"," 或 ",[251,339,340],{},"PORT","（默认为 ",[251,343,344],{},"3000","）",[332,347,348,337,351],{},[251,349,350],{},"NITRO_HOST",[251,352,353],{},"HOST",[332,355,356,359],{},[251,357,358],{},"NITRO_UNIX_SOCKET"," - 如果提供（一个指向所需套接字文件的路径），则服务将通过提供的 UNIX 套接字提供服务。",[332,361,362,365,366,369],{},[251,363,364],{},"NITRO_SSL_CERT"," 和 ",[251,367,368],{},"NITRO_SSL_KEY"," - 如果两者都存在，则服务器将在 HTTPS 模式下启动。在绝大多数情况下，这不应在生产中使用，Nitro 服务器应位于反向代理后，例如 nginx 或 Cloudflare，该代理终止 SSL。",[332,371,372,375,376,379,380,382,383,386],{},[251,373,374],{},"NITRO_SHUTDOWN_DISABLED"," - 当设置为 ",[251,377,378],{},"'true'"," 时，禁用优雅关闭功能。如果设置为 ",[251,381,378],{},"，则将跳过优雅关闭以加速开发过程。默认为 ",[251,384,385],{},"'false'","。",[332,388,389,392,393,386],{},[251,390,391],{},"NITRO_SHUTDOWN_SIGNALS"," - 允许您指定应处理哪些信号。每个信号应以空格分隔。默认为 ",[251,394,395],{},"'SIGINT SIGTERM'",[332,397,398,401,402,405],{},[251,399,400],{},"NITRO_SHUTDOWN_TIMEOUT"," - 设置强制关闭发生前的时间（以毫秒为单位）。默认为 ",[251,403,404],{},"'30000'"," 毫秒。",[332,407,408,411,412,415,416,418,419,386],{},[251,409,410],{},"NITRO_SHUTDOWN_FORCE"," - 当设置为 true 时，在关闭过程结束时触发 ",[251,413,414],{},"process.exit()","。如果设置为 ",[251,417,385],{},"，进程将简单地让事件循环清理。默认为 ",[251,420,378],{},[422,423,424],"h2",{"id":424},"集群模式",[243,426,427,249,429],{},[246,428,248],{},[251,430,431],{},"node_cluster",[243,433,434],{},"为了更高的性能并利用多核处理，您可以使用集群预设。",[322,436,324],{"id":437},"环境变量-1",[243,439,440,441,443],{},"除了来自 ",[251,442,253],{}," 预设的环境变量，您还可以自定义行为：",[329,445,446],{},[332,447,448,451],{},[251,449,450],{},"NITRO_CLUSTER_WORKERS",": 集群工作进程的数量（默认为可用 CPU 内核数量）",[422,453,455],{"id":454},"处理程序高级","处理程序（高级）",[243,457,458,249,460],{},[246,459,248],{},[251,461,462],{},"node",[243,464,465,466,469],{},"Nitro 还有一个更低级的预设，直接导出一个具有 ",[251,467,468],{},"(req, res) => {}"," 签名的函数，可用于中间件和自定义服务器。",[243,471,472,473,475,476,478],{},"当使用 Node 预设运行 ",[251,474,287],{}," 时，结果将是一个导出具有 ",[251,477,468],{}," 签名的函数的入口点。",[243,480,481],{},[246,482,483],{},"示例：",[261,485,489],{"className":486,"code":487,"language":488,"meta":266,"style":266},"language-js shiki shiki-themes github-light github-dark github-dark","import { createServer