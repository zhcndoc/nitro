lass":313}," .output\n",[292,348,350,352,355,358],{"class":294,"line":349},6,[292,351,268],{"class":316},[292,353,354],{"class":313}," deploy",[292,356,357],{"class":342}," --project=my-project",[292,359,360],{"class":313}," server/index.ts\n",[255,362,364],{"id":363},"通过-cicd-使用-github-actions-部署","通过 CI/CD 使用 GitHub Actions 部署",[239,366,367],{},"您只需将 deployctl GitHub Action 作为工作流中的一个步骤包括即可。",[239,369,370,371,375],{},"您不需要为此设置任何密钥。您需要将您的 GitHub 仓库链接到您的 Deno Deploy 项目，并选择 \"GitHub Actions\" 部署模式。您可以在 ",[263,372,161],{"href":373,"rel":374},"https://dash.deno.com",[267]," 的项目设置中完成此操作。",[239,377,378,379,382],{},"在您的 ",[247,380,381],{},".github/workflows"," 目录中创建如下工作流文件：",[283,384,389],{"className":385,"code":386,"filename":387,"language":388,"meta":288,"style":288},"language-yaml shiki shiki-themes github-light github-dark github-dark","name: deno-deploy\n\non:\n  push:\n    branches:\n      - main\n  pull_request:\n    branches:\n      - main\n\njobs:\n  deploy:\n    steps:\n      - uses: actions/checkout@v3\n      - run: corepack enable\n      - uses: actions/setup-node@v3\n        with:\n          node-version: 18\n          cache: pnpm\n      - run: pnpm install\n      - run: pnpm build\n        env:\n          NITRO_PRESET: deno_deploy\n      - name: 部署到 Deno Deploy\n        uses: denoland/deployctl@v1\n        with:\n          project: my-project\n          entrypoint: server/index.ts\n          root: .output\n",".github/workflows/deno_deploy.yml","yaml",[247,390,391,403,407,415,422,429,437,445,452,459,464,472,480,488,501,514,526,534,545,556,568,580,588,599,611,622,629,640,651],{"__ignoreMap":288},[292,392,393,397,400],{"class":294,"line":295},[292,394,396],{"class":395},"sByVh","name",[292,398,399],{"class":305},": ",[292,401,402],{"class":313},"deno-deploy\n",[292,404,405],{"class":294,"line":302},[292,406,330],{"emptyLinePlaceholder":329},[292,408,409,412],{"class":294,"line":326},[292,410,411],{"class":342},"on",[292,413,414],{"class":305},":\n",[292,416,417,