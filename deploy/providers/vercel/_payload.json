,972,973],{},"Authorization"," 请求头。",[424,976,977],{"id":977},"自定义构建输出配置",[395,979,980,981,516,983,986,987,992],{},"你可以在 ",[403,982,515],{},[403,984,985],{},"vercel.config"," 键提供额外的",[418,988,991],{"href":989,"rel":990},"https://vercel.com/docs/build-output-api/v3",[440],"构建输出配置","。它将与内置的自动生成配置合并。",[424,994,996],{"id":995},"按需增量静态再生isr","按需增量静态再生（ISR）",[395,998,999],{},"按需重新验证允许你随时清除 ISR 路由的缓存，无需等待后台重新验证所需的时间间隔。",[395,1001,1002],{},"要按需重新验证页面：",[1004,1005,1007,1025,1088],"steps",{"level":1006},"4",[1008,1009,1010,1011],"h4",{},"创建一个环境变量来存储重新验证密钥",[431,1012,1013],{},[434,1014,1015,1016,747,1019,1024],{},"你可以使用命令 ",[403,1017,1018],{},"openssl rand -base64 32",[418,1020,1023],{"href":1021,"rel":1022},"https://generate-secret.vercel.app/32",[440],"生成密钥"," 来生成随机值。",[1008,1026,1027,1028],{},"更新你的配置：",[527,1029,1031],{"className":529,"code":1030,"filename":531,"language":532,"meta":5,"style":5},"import { defineNitroConfig } from \"nitro/config\";\n\nexport default defineNitroConfig({\n  vercel: {\n    config: {\n      bypassToken: process.env.VERCEL_BYPASS_TOKEN\n    }\n  }\n})\n",[403,1032,1033,1045,1049,1059,1063,1068,1076,1080,1084],{"__ignoreMap":5},[536,1034,1035,1037,1039,1041,1043],{"class":538,"line":539},[536,1036,852],{"class":542},[536,1038,855],{"class":553},[536,1040,858],{"class":542},[536,1042,861],{"class":575},[536,1044,864],{"class":553},[536,1046,1047],{"class":538,"line":557},[536,1048,870],{"emptyLinePlaceholder":869},[536,1050,1051,1053,1055,1057],{"class":538,"line":563},[536,1052,543],{"class":542},[536,1054,546],{"class":542},[536,1056,550],{"class":549},[536,1058,554],{"class":553},[536,1060,1061],{"class":538,"line":569},[536,1062,560],{"class":553},[536,1064,1065],{"class":538,"line":579},[536,1066,1067],{"class":553},"    config: {\n",[536,1069,1070,1073],{"class":538,"line":585},[536,1071,1072],{"class":553},"      bypassToken: process.env.",[536,1074,1075],{"class":622},"VERCEL_BYPASS_TOKEN\n",[536,1077,1078],{"class":538,"line":591},[536,107