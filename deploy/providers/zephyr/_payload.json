h":387,"stem":388},"/","index",{"id":390,"title":205,"body":391,"description":895,"extension":896,"meta":897,"navigation":898,"path":206,"seo":899,"stem":207,"__hash__":900},"content/2.deploy/20.providers/zephyr.md",{"type":392,"value":393,"toc":886},"minimark",[394,406,411,417,426,432,437,440,448,452,455,486,496,499,506,512,602,605,609,612,649,653,663,842,854,857,863,872,882],[395,396,397,401,402],"p",{},[398,399,400],"strong",{},"预设："," ",[403,404,405],"code",{},"zephyr",[407,408],"read-more",{"title":409,"to":410},"Zephyr Cloud 文档","https://docs.zephyr-cloud.io",[395,412,413,414,416],{},"Zephyr 支持通过 ",[403,415,405],{}," 预设内置于 Nitro 中。",[395,418,419,420,425],{},"对于大多数 Zephyr 特定的主题，例如 BYOC、云集成、环境和 CI/CD 认证，请参阅 ",[421,422,409],"a",{"href":410,"rel":423},[424],"nofollow","。",[427,428,429],"note",{},[395,430,431],{},"Zephyr 与大多数 Nitro 部署提供商有所不同。它不是直接面向单一托管供应商，而是作为部署控制平面，运行在 Zephyr 管理的基础设施或你自己的云集成之上。",[433,434,436],"h2",{"id":435},"byoc-模式","BYOC 模式",[395,438,439],{},"Zephyr 支持 BYOC（自带云）模式。在 Zephyr 的架构中，控制平面由 Zephyr 管理，而数据平面（工作进程和存储）则运行在你的云账户中。",[395,441,442,443,425],{},"这使你可以在使用任何受支持的 Zephyr 云集成的服务的同时，保持 Zephyr 的部署工作流程。有关当前支持的提供商列表，请参阅 ",[421,444,447],{"href":445,"rel":446},"https://docs.zephyr-cloud.io/features/byoc",[424],"Zephyr BYOC 文档",[433,449,451],{"id":450},"使用-nitro-cli-部署","使用 Nitro CLI 部署",[395,453,454],{},"使用 Nitro 的部署命令，一键完成构建并上传应用到 Zephyr：",[456,457,461],"pre",{"className":458,"code":459,"language":460,"meta":5,"style":5},"language-bash shiki shiki-themes github-light github-dark github-dark","npx nitro deploy --preset zephyr\n","bash",[403,462,463],{"__ignoreMap":5},[464,465,468,472,476,479,483],"span",{"class":466,"line":467},"line",1,[464,469,471],{"class":470},"shcOC","npx",[464,473,475],{"class":474},"sfrk1"," nitro",[464,477,478],{"class":474}," deploy",[464,480,482],{"class":481},"suiK_"," --preset",[464,484,485],{"class":474}," zephyr\n",[395,487,488,489,492,493,495],{},"Nitro 将使用 ",[403,490,491],{},"zephyr-agent"," 上传生成的输出。如果缺少 ",[403,494,491],{},"，Nitro 将提示在本地安装，并会在 CI 环境中自动安装。",[433,497,498],{"id":498},"构建时部署",[395,500,501,502,505],{},"在这一方面，Zephyr 与大多数 Nitro 提供商有所不同：我们建议启用 ",[403,503,504],{},"nitro build"," 期间的部署，并将构建视为主要的部署步骤。",[395,507,508,509,511],{},"如果你的 CI 流水线已经运行 ",[403,510,504],{},"，请在构建步骤期间启用部署：",[456,513,518],{"className":514,"code":515,"filename":516,"language":517,"meta":5,"style":5},"language-ts shiki shiki-themes github-light github-dark github-dark","import { defineNitroConfig } from \"nitro/config\";\n\nexport default defineNitroConfig({\n  preset: \"zephyr\",\n  zephyr: {\n    deployOnBuild: true,\n  },\n});\n","nitro.config.ts","ts",[403,519,520,539,546,561,573,579,590,596],{"__ignoreMap":5},[464,521,522,526,530,533,536],{"class":466,"line":467},[464,523,525],{"class":524},"so5gQ","import",[464,527,529],{"class":528},"slsVL"," { defineNitroConfig } ",[464,531,532],{"class":524},"from",[464,534,535],{"class":474}," \"nitro/config\"",[464,537,538],{"class":528},";\n",[464,540,542],{"class":466,"line":541},2,[464,543,545],{"emptyLinePlaceholder":544},true,"\n",[464,547,549,552,555,558],{"class":466,"line":548},3,[464,550,551],{"class":524},"export",[464,553,554],{"class":524}," default",[464,556,557],{"class":470}," defineNitroConfig",[464,559,560],{"class":528},"({\n",[464,562,564,567,570],{"class":466,"line":563},4,[464,565,566],{"class":528},"  preset: ",[464,568,569],{"class":474},"\"zephyr\"",[464,571,572],{"class":528},",\n",[464,574,576],{"class":466,"line":575},5,[464,577,578],{"class":528},"  zephyr: {\n",[464,580,582,585,588],{"class":466,"line":581},6,[464,583,584],{"class":528},"    deployOnBuild: ",[464,586,587],{"class":481},"true",[464,589,572],{"class":528},[464,591,593],{"class":466,"line":592},7,[464,594,595],{"class":528},"  },\n",[464,597,599],{"class":466,"line":598},8,[464,600,601],{"class":528},"});\n",[395,603,604],{},"这样你正常的构建命令就足够了：",[606,607],"pm-run",{"script":608},"build",[395,610,611],{},"构建完成后，Nitro 会将生成的输出上传到 Zephyr，部署到边缘节点，并打印部署 URL：",[456,613,617],{"class