 --git",[483,625,626],{"class":493}," github.com/",[483,628,629],{"class":602},"\u003C",[483,631,632],{"class":493},"YOUR_GITHUB_USERNAM",[483,634,610],{"class":609},[483,636,613],{"class":602},[483,638,387],{"class":493},[483,640,629],{"class":602},[483,642,643],{"class":493},"YOUR_REPOSITORY_NAM",[483,645,610],{"class":609},[483,647,613],{"class":602},[483,649,617],{"class":616},[483,651,653,656,659],{"class":485,"line":652},3,[483,654,655],{"class":616},"   --git-branch",[483,657,658],{"class":493}," main",[483,660,617],{"class":616},[483,662,664,667,670],{"class":485,"line":663},4,[483,665,666],{"class":616},"   --git-run-command",[483,668,669],{"class":493}," \"node .output/server/index.mjs\"",[483,671,617],{"class":616},[483,673,675,678,681],{"class":485,"line":674},5,[483,676,677],{"class":616},"   --ports",[483,679,680],{"class":493}," 3000:http",[483,682,617],{"class":616},[483,684,686,689,692],{"class":485,"line":685},6,[483,687,688],{"class":616},"   --routes",[483,690,691],{"class":493}," /:3000",[483,693,617],{"class":616},[483,695,697,700,703,706],{"class":485,"line":696},7,[483,698,699],{"class":616},"   --env",[483,701,702],{"class":493}," PORT=",[483,704,705],{"class":616},"3000",[483,707,617],{"class":616},[483,709,711,713],{"class":485,"line":710},8,[483,712,699],{"class":616},[483,714,715],{"class":493}," NITRO_PRESET=koyeb\n",[411,717,719],{"id":718},"使用-docker-容器","使用 Docker 容器",[415,721,722,737],{"level":417},[419,723,724,725,728,729],{},"在项目的根目录创建一个 ",[403,726,727],{},".dockerignore"," 文件，并添加以下行：",[475,730,735],{"className":731,"code":733,"language":734},[732],"language-text","Dockerfile\n.dockerignore\nnode_modules\nnpm-debug.log\n.nitro\n.output\n.git\ndist\nREADME.md\n","text",[403,736,733],{"__ignoreMap":5},[419,738,739,740,743,744],{},"在项目的根目录添加一个 ",[403,741,742],{},"Dockerfile","：",[475,745,748],{"className":746,"code":747,"language":734},[732],"FROM node:18-alpine AS base\n\nFROM base AS deps\nRUN apk add --no-cache libc6-compat\nWORKDIR /app\nCOPY package.json package-lock.json ./\nRUN npm ci\n\nFROM base AS builder\nWORKDIR /app\nCOPY --from=deps /app/node_modules ./node_modules\nCOPY . .\nRUN npm run build && npm cache clean --force\n\nFROM base AS runner\nWORKDIR /app\nRUN addgroup --system --gid 1001 nodejs\nRUN adduser --system --uid 1001 nitro\nCOPY --from=builder /app .\nUSER nitro\nEXPOSE 3000\nENV PORT 3000\nCMD [\"npm\", \"run\", \"start\"]\n",[403,749,747],{"__ignoreMap":5},[395,751,752,753,758,759,764,765,770,771,451],{},"上面的 Dockerfile 提供了运行 Nitro 应用的最低要求。您可以根据自己的需要轻松扩展它。\n然后您需要将 Docker 镜像推送到镜像仓库。例如，您可以使用 ",[423,754,757],{"href":755,"rel":756},"https://hub.docker.com/",[427],"Docker Hub"," 或 ",[423,760,763],{"href":761,"rel":762},"https://docs.github.com/en/packages/guides/about-github-container-registry",[427],"GitHub Container Registry","。\n在 Koyeb 控制面板中，使用 image 和 tag 字段来指定要部署的镜像。\n您也可以使用 ",[423,766,769],{"href":767,"rel":768},"https://www.koyeb.com/docs/build-and-deploy/cli/installation",[427],"Koyeb CLI","\n有关更多信息，请参阅 Koyeb 的 ",[423,772,775],{"href":773,"rel":774},"https://www.koyeb.com/docs/build-and-deploy/prebuilt-docker-images",[427],"Docker 文档",[777,778,779],"style",{},"html pre.shiki code .shcOC, html code.shiki .shcOC{--shiki-light:#6F42C1;--shiki-default:#B392F0;--shiki-dark:#B392F0}html pre.shiki code .sfrk1, html code.shiki .sfrk1{--shiki-light:#032F62;--shiki-default:#9ECBFF;--shiki-dark:#9ECBFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);