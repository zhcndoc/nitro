_GITHUB_USERNAM",[327,477,453],{"class":452},[327,479,456],{"class":445},[327,481,482],{"class":337},"/",[327,484,472],{"class":445},[327,486,487],{"class":337},"YOUR_REPOSITORY_NAM",[327,489,453],{"class":452},[327,491,456],{"class":445},[327,493,460],{"class":459},[327,495,497,500,503],{"class":329,"line":496},3,[327,498,499],{"class":459},"   --git-branch",[327,501,502],{"class":337}," main",[327,504,460],{"class":459},[327,506,508,511,514],{"class":329,"line":507},4,[327,509,510],{"class":459},"   --git-run-command",[327,512,513],{"class":337}," \"node .output/server/index.mjs\"",[327,515,460],{"class":459},[327,517,519,522,525],{"class":329,"line":518},5,[327,520,521],{"class":459},"   --ports",[327,523,524],{"class":337}," 3000:http",[327,526,460],{"class":459},[327,528,530,533,536],{"class":329,"line":529},6,[327,531,532],{"class":459},"   --routes",[327,534,535],{"class":337}," /:3000",[327,537,460],{"class":459},[327,539,541,544,547,550],{"class":329,"line":540},7,[327,542,543],{"class":459},"   --env",[327,545,546],{"class":337}," PORT=",[327,548,549],{"class":459},"3000",[327,551,460],{"class":459},[327,553,555,557],{"class":329,"line":554},8,[327,556,543],{"class":459},[327,558,559],{"class":337}," NITRO_PRESET=koyeb\n",[255,561,563],{"id":562},"使用-docker-容器","使用 Docker 容器",[259,565,566,581],{"level":261},[263,567,568,569,572,573],{},"在项目的根目录中创建一个 ",[247,570,571],{},".dockerignore"," 文件，并添加以下行：",[318,574,579],{"className":575,"code":577,"language":578},[576],"language-text","Dockerfile\n.dockerignore\nnode_modules\nnpm-debug.log\n.nitro\n.output\n.git\ndist\nREADME.md\n","text",[247,580,577],{"__ignoreMap":323},[263,582,583,584,587,588],{},"在项目的根目录中添加一个 ",[247,585,586],{},"Dockerfile","：",[318,589,592],{"className":590,"code":591,"language":578},[576],"FROM node:18-alpine AS base\n\nFROM base AS deps\nRUN apk add --no-cache libc6-compat\nWORKDIR /app\nCOPY package.json package-lock.json ./\nRUN npm ci\n\nFROM base AS builder\nWORKDIR /app\nCOPY --from=deps /app/node_modules ./node_modules\nCOPY . .\nRUN npm run build && npm cache clean --force\n\nFROM base AS runner\nWORKDIR /app\nRUN addgroup --system --gid 1001 nodejs\nRUN adduser --system --uid 1001 nitro\nCOPY --from=builder /app .\nUSER nitro\nEXPOSE 3000\nENV PORT 3000\nCMD [\"npm\", \"run\", \"start\"]\n",[247,593,591],{"__ignoreMap":323},[239,595,596,597,602,603,608,609,614,615,277],{},"上面的 Dockerfile 提供了运行 Nitro 应用程序的最低要求。您可以根据您的需求轻松扩展它。\n然后，您需要将 Docker 镜像推送到一个注册表。您可以使用 ",[267,598,601],{"href":599,"rel":600},"https://hub.docker.com/",[271],"Docker Hub"," 或 ",[267,604,607],{"href":605,"rel":606},"https://docs.github.com/en/packages/guides/about-github-container-registry",[271],"GitHub Container Registry"," 等。\n在 Koyeb 控制面板中，使用镜像和标签字段指定您要部署的镜像。\n您还可以使用 ",[267,610,613],{"href":611,"rel":612},"https://www.koyeb.com/docs/build-and-deploy/cli/installation",[271],"Koyeb CLI","。\n有关更多信息，请参考 Koyeb ",[267,616,619],{"href":617,"rel":618},"https://www.koyeb.com/docs/build-and-deploy/prebuilt-docker-images",[271],"Docker 文档",[621,622,623],"style",{},"html pre.shiki code .shcOC, html code.shiki .shcOC{--shiki-light:#6F42C1;--shiki-default:#B392F0;--shiki-dark:#B392F0}html pre.shiki code .sfrk1, html code.shiki .sfrk1{--shiki-light:#032F62;--shiki-default:#9ECBFF;--shiki-dark:#9ECBFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span 