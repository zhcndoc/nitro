fig","3.config/0.index",[236],{"title":67,"path":233,"stem":234,"icon":70},{"id":238,"title":82,"body":239,"description":527,"extension":528,"meta":529,"navigation":531,"path":83,"seo":532,"stem":84,"__hash__":533},"content/2.deploy/0.index.md",{"type":240,"value":241,"toc":521,"icon":87},"minimark",[242,246,250,259,267,270,273,318,328,331,349,352,362,391,400,438,441,444,447,454,457,517],[243,244,245],"p",{},"Nitro 可以从相同的代码库生成适合不同托管提供者的不同输出格式。通过使用内置的预设，您可以轻松配置 Nitro 以几乎不需要额外代码或配置地调整其输出格式！",[247,248,249],"h2",{"id":249},"默认输出",[243,251,252,253,258],{},"默认的生产输出预设是 ",[254,255,257],"a",{"href":256},"/deploy/node","Node.js server","。",[243,260,261,262,266],{},"在开发模式下运行 Nitro 时，Nitro 总是会使用名为 ",[263,264,265],"code",{},"nitro-dev"," 的特殊预设，该预设使用 Node.js 以 ESM 的形式在隔离的 Worker 环境中运行，尽可能接近生产环境的行为。",[247,268,269],{"id":269},"零配置提供者",[243,271,272],{},"在使用 CI/CD 部署生产环境时，Nitro 会尝试自动检测提供者环境并相应地设置正确的配置，无需任何额外配置。目前，以下提供者可以通过零配置自动检测。",[274,275,276,282,287,292,298,303,308,313],"ul",{},[277,278,279],"li",{},[254,280,281],{"href":146},"aws amplify",[277,283,284],{},[254,285,286],{"href":150},"azure",[277,288,289],{},[254,290,291],{"href":158},"cloudflare",[277,293,294],{},[254,295,297],{"href":296},"/deploy/providers/firebase#firebase-app-hosting","firebase app hosting",[277,299,300],{},[254,301,302],{"href":206},"netlify",[277,304,305],{},[254,306,307],{"href":218},"stormkit",[277,309,310],{},[254,311,312],{"href":222},"vercel",[277,314,315],{},[254,316,317],{"href":226},"zeabur",[319,320,321],"warning",{},[243,322,323,324,327],{},"对于 Turborepo 用户，零配置检测将受到其严格环境模式的干扰。您可能需要显式地允许变量，或使用其宽松环境模式（使用 ",[263,325,326],{},"--env-mode=loose"," 标志）。",[247,329,330],{"id":330},"更改部署预设",[243,332,333,334,337,338,341,342,344,345,348],{},"如果您需要针对特定提供者构建 Nitro，您可以通过定义名为 ",[263,335,336],{},"NITRO_PRESET"," 或 ",[263,339,340],{},"SERVER_PRESET"," 的环境变量，或者通过更新您的 Nitro ",[254,343,67],{"href":68},"，或使用 ",[263,346,347],{},"--preset"," 参数来指定目标。",[243,350,351],{},"建议在依赖于 CI/CD 的部署中使用环境变量的方法。",[243,353,354,358,359,361],{},[355,356,357],"strong",{},"示例："," 定义 ",[263,360,336],{}," 环境变量",[363,364,369],"pre",{"className":365,"code":366,"language":367,"meta":368,"style":368},"language-bash shiki shiki-themes github-light github-dark github-dark","nitro build --preset cloudflare_pages\n","bash","",[263,370,371],{"__ignoreMap":368},[372,373,376,380,384,388],"span",{"class":374,"line":375},"line",1,[372,377,379],{"class":378},"shcOC","nitro",[372,381,383],{"class":382},"sfrk1"," build",[372,385,387],{"class":386},"suiK_"," --preset",[372,389,390],{"class":382}," cloudflare_pages\n",[243,392,393,395,396,399],{},[355,394,357],{}," 更新 ",[263,397,398],{},"nitro.config.ts"," 文件",[363,401,405],{"className":402,"code":403,"language":404,"meta":368,"style":368},"language-ts shiki shiki-themes github-light github-dark github-dark","export default defineNitroConfig({\n  preset: 'cloudflare_pages'\n})\n","ts",[263,406,407,423,432],{"__ignoreMap":368},[372,408,409,413,416,419],{"class":374,"line":375},[372,410,412],{"class":411},"so5gQ","export",[372,414,415],{"class":411}," default",[372,417,418],{"class":378}," defineNitroConfig",[372,420,422],{"class":421},"slsVL","({\n",[372,424,426,429],{"class":374,"line":425},2,[372,427,428],{"class":421},"  preset: ",[372,430,431],{"class":382},"'cloudflare_pages'\n",[372,433,435],{"class":374,"line":434},3,[372,436,437],{"class":421},"})\n",[247,439,440],{"id":440},"兼容性日期",[243,442,443],{},"部署提供者定期更新他们的运行时行为。Nitro 预设会更新以支持这些新功能。",[243,445,446],{},"为了防止破坏现有部署，Nitro 使用兼容性日期。该日期允许您在项目创建时锁定行为。您还可以选择在准备好时选择未来的更新。",[243,448,449,450,453],{},"当您创建一个新项目时，",[263,451,452],{},"compatibilityDate"," 被设置为当前日期。此设置会保存在您的项目配置中。",[243,455,456],{},"您应该定期更新兼容性日期。更新后，请始终彻底测试您的部署。以下是关键日期及其影响的列表。",[458,459,460,476],"table",{},[461,462,463],"thead",{},[464,465,466,470,473],"tr",{},[467,468,469],"th",{},"Compatibility date",[467,471,472],{},"Platform",[467,474,475],{},"Description",[477,478,479,492,504],"tbody",{},[464,480,481,487,489],{},[482,483,484],"td",{},[355,485,486],{},"≥ 2