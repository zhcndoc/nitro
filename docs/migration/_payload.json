e":457,"meta":5,"style":5},"-- const { cloudflare } = event.context\n-- const binding = cloudflare.env.MY_BINDING\n++ const { env } = event.req.runtime.cloudflare\n++ const binding = env.MY_BINDING\n",[409,889,890,895,900,905],{"__ignoreMap":5},[461,891,892],{"class":463,"line":464},[461,893,894],{"class":480},"-- const { cloudflare } = event.context\n",[461,896,897],{"class":463,"line":471},[461,898,899],{"class":480},"-- const binding = cloudflare.env.MY_BINDING\n",[461,901,902],{"class":463,"line":477},[461,903,904],{"class":487},"++ const { env } = event.req.runtime.cloudflare\n",[461,906,907],{"class":463,"line":484},[461,908,909],{"class":487},"++ const binding = env.MY_BINDING\n",[405,911,913],{"id":912},"更改的-nitro-子路径导入","更改的 nitro 子路径导入",[398,915,916],{},"Nitro v2 引入了多个子路径导出，其中一些已被移除或更新：",[605,918,919,932,939,945],{},[608,920,921,924,925,928,929,724],{},[409,922,923],{},"nitro/rollup","、",[409,926,927],{},"nitropack/core","（使用 ",[409,930,931],{},"nitro/builder",[608,933,934,928,937,724],{},[409,935,936],{},"nitropack/runtime/*",[409,938,561],{},[608,940,941,944],{},[409,942,943],{},"nitropack/kit","（已移除）",[608,946,947,944],{},[409,948,949],{},"nitropack/presets",[398,951,952,953,955],{},"实验性的 ",[409,954,943],{}," 曾被引入，但现已移除。未来可能会推出独立的 Nitro Kit 包，目标更加明确。",[398,957,958],{},[434,959,436],{},[605,961,962,975],{},[608,963,610,964,966,967,970,971,974],{},[409,965,629],{}," 中的 ",[409,968,969],{},"NitroModule"," 替代 kit 中的 ",[409,972,973],{},"defineNitroModule","。",[608,976,977],{},"优先使用内置的 Nitro 预设（外部预设仅用于评估目的）。",[405,979,981],{"id":980},"h3-v2","H3 v2",[398,983,984,985,989,990,993],{},"Nitro v3 升级到 ",[420,986,981],{"href":987,"rel":988},"https://h3.dev",[424],"，其中包含 API 更改。所有 H3 工具从 ",[409,991,992],{},"nitro/h3"," 导入。",[995,996,998],"h3",{"id":997},"web-标准","Web 标准",[398,1000,1001,1002,924,1009,924,1016,1023,1024,1031],{},"H3 v2 基于 Web 标准原语（",[420,1003,1006],{"href":1004,"rel":1005},"https://developer.mozilla.org/en-US/docs/Web/API/URL",[424],[409,1007,1008],{},"URL",[420,1010,1013],{"href":1011,"rel":1012},"https://developer.mozilla.org/en-US/docs/Web/API/Headers",[424],[409,1014,1015],{},"Headers",[420,1017,1020],{"href":1018,"rel":1019},"https://developer.mozilla.org/en-US/docs/Web/API/Request",[424],[409,1021,1022],{},"Request"," 和 ",[420,1025,1028],{"href":1026,"rel":1027},"https://developer.mozilla.org/en-US/docs/Web/API/Response",[424],[409,1029,1030],{},"Response","）重写。",[398,1033,1034,1035,974,1038,1041,1042,1045,1046,1051],{},"仅在 Node.js 运行时中可访问 ",[409,1036,1037],{},"event.node.{req,res}",[409,1039,1040],{},"event.web"," 已重命名为 ",[409,1043,1044],{},"event.req","（Web ",[420,1047,1049],{"href":1018,"rel":1048},[424],[409,1050,1022],{}," 的实例）。",[995,1053,1054],{"id":1054},"响应处理",[398,1056,1057,1058,1061,1062,1065],{},"你应该始终显式地 ",[434,1059,1060],{},"return"," 响应体或 ",[434,1063,1064],{},"throw"," 一个错误：",[452,1067,1069],{"className":454,"code":1068,"language":457,"meta":5,"style":5},"-- import { send, sendRedirect, sendStream } from \"nitro/h3\"\n-- send(event, value)\n-- sendStream(event, stream)\n-- sendRedirect(event, location, code)\n++ import { redirect } from \"nitro/h3\"\n++ return value\n++ return stream\n++ return redirect(event, location, code)\n",[409,1070,1071,1076,1081,1086,1091,1096,1101,1107],{"__ignoreMap":5},[461,1072,1073],{"class":463,"line":464},[461,1074,1075],{"class":480},"-- import { send, sendRedirect, sendStream } from \"nitro/h3\"\n",[461,1077,1078],{"class":463,"line":471},[461,1079,1080],{"class":480},"-- send(event, value)\n",[461,1082,1083],{"class":463,"line":477},[461,1084,1085],{"class":480},"-- sendStream(event, stream)\n",[461,1087,1088],{"class":463,"line":484},[461,1089,1090],{"class":480},"-- sendRedirect(event, location, code)\n",[461,1092,1093],{"class":463,"line":491},[461,1094,1095],{"class":487},"++ import { redirect } from \"nitro/h3\"\n",[461,1097,1098],{"class":463,"line":497},[461,1099,1100],{"class":487},"++ return value\n",[461,1102,1104],{"class":463,"line":1103},7,[461,1105,1106],{"class":487},"++ return stream\n",[461,1108,1110],{"class":463,"line":1109},8,[461,1111,1112],{"class":487},"++ return redirect(event, location, code)\n",[398,1114,1115],{},"其他更改：",[605,1117,1118,1127,1135],{},[608,1119,1120,1123,1124],{},[409,1121,1122],{},"sendError(event, error)"," → ",[409,1125,1126],{},"throw createError(error)",[608,1128,1129,1123,1132],{},[409,1130,1131],{},"sendNoContent(event)",[409,1133,1134],{},"return noContent(event)",[608,1136,1137,1123,1140],{},[409,1138,1139],{},"sendProxy(event, target)",[409,1141,1142],{},"return proxy(event, target)",[995,1144,1145],{"id":1145},"请求体",[398,1147,1148,1149,1151],{},"大多数 body 工具可以被原生的 ",[409,1150,1044],{}," 方法替代：",[452,1153,1155],{"className":454,"code":1154,"language":457,"meta":5,"style":5},"-- import { readBody, readRawBody, readFormData } from \"nitro/h3\"\n++ // 使用原生 Request 方法\n++ const json = await event.req.json()\n++ const text = await event.req.text()\n++ const formData = await event.req.formData()\n++ const stream = event.req.body\n",[409,1156,1157,1162,1167,1172,1177,1182],{"__ignoreMap":5},[461,1158,1159],{"class":463,"line":464},[461,1160,1161],{"class":480},"-- import { readBody, readRawBody, readFormData } from \"nitro/h3\"\n",[461,1163,1164],{"class":463,"line":471},[461,1165,1166],{"class":487},"++ // 使用原生 Request 方法\n",[461,1168,1169],{"class":463,"line":477},[461,1170,1171],{"class":487},"++ const json = await event.req.json()\n",[461,1173,1174],{"class":463,"line":484},[461,1175,1176],{"class":487},"++ const text = await event.req.text()\n",[461,1178,1179],{"class":463,"line":491},[461,1180,1181],{"class":487},"++ const formData = await event.req.formData()\n",[461,1183,1184],{"class":463,"line":497},[461,1185,1186],{"class":487},"++ const stream = event.req.body\n",[995,1188,1189],{"id":1189},"请求头",[398,1191,1192,1193,1198,1199,1202,1203,924,1206,769,1209,1212],{},"H3 现在使用标准 Web ",[420,1194,1196],{"href":1011,"rel":1195},[424],[409,1197,1015],{},"。请求头的值始终是纯 ",[409,1200,1201],{},"string","（没有 ",[409,1204,1205],{},"null",[409,1207,1208],{},"undefined",[409,1210,1211],{},"string[]","）。",[452,1214,1216],{"className":454,"code":1215,"language":457,"meta":5,"style":5},"-- import { getHeader, setHeader, getResponseStatus } from \"nitro/h3\"\n-- getHeader(event, \"x-foo\")\n-- setHeader(event, \"x-foo\", \"bar\")\n++ event.req.headers.get(\"x-foo\")\n++ event.res.headers.set(\"x-foo\", \"bar\")\n++ event.res.status // 替代 getResponseStatus(event)\n",[409,1217,1218,1223,1228,1233,1238,1243],{"__ignoreMap":5},[461,1219,1220],{"class":463,"line":464},[461,1221,1222],{"class":480},"-- import { getHeader, setHeader, getResponseStatus } from \"nitro/h3\"\n",[461,1224,1225],{"class":463,"line":471},[461,1226,1227],{"class":480},"-- getHeader(event, \"x-foo\")\n",[461,1229,1230],{"class":463,"line":477},[461,1231,1232],{"class":480},"-- setHeader(event, \"x-foo\", \"bar\")\n",[461,1234,1235],{"class":463,"line":484},[461,1236,1237],{"class":487},"++ event.req.headers.get(\"x-foo\")\n",[461,1239,1240],{"class":463,"line":491},[461,1241,1242],{"class":487},"++ event.res.headers.set(\"x-foo\", \"bar\")\n",[461,1244,1245],{"class":463,"line":497},[461,1246,1247],{"class":487},"++ event.res.status // 替代 getResponseStatus(event)\n",[995,1249,1250],{"id":1250},"处理器工具",[452,1252,1254],{"className":454,"code":1253,"language":457,"meta":5,"style":5},"-- import { eventHandler, defineEventHandler } from \"nitro/h3\"\n++ import { defineHandler } from \"nitro\"\n",[409,1255,1256,1261],{"__ignoreMap":5},[461,1257,1258],{"class":463,"line":464},[461,1259,1260],{"class":480},"-- import { eventHandler, defineEventHandler } from \"nitro/h3\"\n",[461,1262,1263],{"class":463,"line":471},[461,1264,1265],{"class":487},"++ import { defineHandler } from \"nitro\"\n",[605,1267,1268,1276],{},[608,1269,1270,1123,1273],{},[409,1271,1272],{},"lazyEventHandler",[409,1274,1275],{},"defineLazyEventHandler",[608,1277,1278,1123,1281],{},[409,1279,1280],{},"useBase",[409,1282,1283]